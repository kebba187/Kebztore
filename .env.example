# ─────────────────────────────────────────────────────────────────────────────
# Кебзtore — environment variables (copy to `.env` and fill in REAL values).
# `.env` is gitignored. NEVER commit real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# --- Django core ---
DJANGO_SECRET_KEY=replace-with-50-random-chars-keep-secret
DJANGO_DEBUG=True                 # MUST be False in production
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,kebztore.ru
# Needed for HTTPS form POSTs in production (include the scheme):
DJANGO_CSRF_TRUSTED_ORIGINS=https://kebztore.ru,https://www.kebztore.ru

# --- PostgreSQL (host MUST be physically in Russia: Yandex.Cloud / SberCloud / Timeweb) ---
# 152-ФЗ: personal data of RF citizens must be stored on servers located in Russia.
DATABASE_URL=postgres://kebztore:password@localhost:5432/kebztore

# --- YooKassa (ЮKassa) sandbox credentials ---
# Get them in the YooKassa merchant dashboard -> "Тестовый магазин".
# Mir / SberPay / Mir Pay / SBP(СБП) QR / YooMoney are all enabled there.
YOOKASSA_SHOP_ID=test_shop_id_placeholder
YOOKASSA_SECRET_KEY=test_secret_key_placeholder
YOOKASSA_RETURN_URL=http://localhost:8000/orders/payment/return/

# --- Email (order confirmations / password reset). Use a Russian SMTP in prod. ---
EMAIL_HOST=smtp.yandex.ru
EMAIL_HOST_USER=noreply@kebztore.ru
EMAIL_HOST_PASSWORD=app-password-placeholder
EMAIL_PORT=465
EMAIL_USE_SSL=True
DEFAULT_FROM_EMAIL=Кебзtore <noreply@kebztore.ru>

# --- Error monitoring (Sentry) — optional. Leave blank to disable. ---
# 152-ФЗ: we send NO personal data to Sentry (send_default_pii=False). For strict
# compliance, self-host Sentry on a Russian server.
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.0
