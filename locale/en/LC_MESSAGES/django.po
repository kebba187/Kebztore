# ── personal data page ──────────────────────────────────────────────────────
msgid "Обработка персональных данных"
msgstr "Personal data processing"

msgid "В соответствии с Федеральным законом № 152-ФЗ «О персональных данных»."
msgstr "In accordance with Federal Law No. 152-FZ \"On Personal Data\"."

msgid "Какие данные мы собираем"
msgstr "What data we collect"

msgid "ФИО, email и телефон — для связи и оформления заказа."
msgstr "Full name, email and phone — for contact and order processing."

msgid "Адрес доставки — для отправки товара."
msgstr "Delivery address — to ship the order."

msgid "Технические данные (cookie сессии) — для работы корзины и авторизации."
msgstr "Technical data (session cookies) — for the cart and authentication."

msgid "Зачем мы их собираем"
msgstr "Why we collect it"

msgid "Исключительно для исполнения договора купли-продажи, доставки заказа и поддержки клиентов. Мы не передаём данные третьим лицам, кроме служб доставки и платёжного провайдера (ЮKassa) в объёме, необходимом для исполнения заказа."
msgstr "Solely to fulfil the sales contract, deliver the order and support customers. We do not share data with third parties, except delivery services and the payment provider (YooKassa) to the extent necessary to fulfil the order."

msgid "Где и как хранятся данные"
msgstr "Where and how data is stored"

msgid "Персональные данные граждан РФ хранятся и обрабатываются на серверах, расположенных на территории Российской Федерации (например, Yandex.Cloud / SberCloud / Timeweb). Доступ к данным ограничен, передача защищена по протоколу HTTPS. Данные платёжных карт мы не храним — оплата проходит на стороне ЮKassa."
msgstr "Personal data of Russian citizens is stored and processed on servers located in the Russian Federation (e.g. Yandex.Cloud / SberCloud / Timeweb). Access is restricted and transfers are protected via HTTPS. We do not store payment card data — payment is handled on YooKassa's side."

msgid "Категории cookie"
msgstr "Cookie categories"

msgid "необходимы для работы сайта (сессия, корзина). Всегда включены."
msgstr "required for the site to work (session, cart). Always on."

msgid "помогают понять, как используется сайт. Только с вашего согласия."
msgstr "help us understand how the site is used. Only with your consent."

msgid "используются для маркетинга. Только с вашего согласия."
msgstr "used for marketing. Only with your consent."

msgid "Ваши права по 152-ФЗ"
msgstr "Your rights under 152-FZ"

msgid "получить информацию об обработке ваших данных;"
msgstr "obtain information about the processing of your data;"

msgid "потребовать уточнения, блокировки или удаления данных;"
msgstr "request correction, blocking or deletion of data;"

msgid "отозвать согласие на обработку."
msgstr "withdraw consent to processing."

msgid "Запросы направляйте на"
msgstr "Send requests to"

